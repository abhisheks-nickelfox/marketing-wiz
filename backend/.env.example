PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aiwealth_db
DB_USER=aiwealth_user
DB_PASSWORD=your_db_password

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=your-avatars-bucket-name
AWS_SES_FROM=noreply@aiwealth.com

# ── AI / Fireflies ────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_or_groq_key
FIREFLIES_API_KEY=your_fireflies_key
AI_MODEL=llama-3.3-70b-versatile

# ── SMTP (optional — falls back to console log when absent) ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@marketingwiz.app

# ── Super admin bootstrap ─────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@youragency.com
SUPER_ADMIN_PASSWORD=supersecret123
SUPER_ADMIN_NAME=Super Admin
